<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.leehuang.his.api.db.dao.RuleDao">

    <!-- 查询规则列表分页数据 -->
    <select id="searchRuleDataByPage" resultType="com.leehuang.his.api.mis.dto.rule.vo.RulePageVO">
        SELECT
            r.id,
            r.name as ruleName,
            (SELECT COUNT(*) FROM tb_goods g WHERE g.rule_id = r.id) AS count,
            r.remark
        FROM tb_rule r
        <where>
            <if test="request.name != null and request.name != ''">
                AND r.name LIKE CONCAT('%', #{request.name}, '%')
            </if>
        </where>
        ORDER BY r.id
        LIMIT #{start}, #{request.length}
    </select>

    <!-- 查询规则列表分页数据总数 -->
    <select id="searchRuleDataCount" resultType="java.lang.Integer">
        SELECT COUNT(*)
            FROM tb_rule r
        <where>
            <if test="request.name != null and request.name != ''">
                AND r.name LIKE CONCAT('%', #{request.name}, '%')
            </if>
        </where>
    </select>

</mapper>
